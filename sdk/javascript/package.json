{
  "name": "tako.sh",
  "version": "0.0.0",
  "description": "Official SDK for the Tako application platform",
  "keywords": [
    "bun",
    "deployment",
    "node",
    "serverless",
    "tako",
    "tako.sh"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lilienblum/tako.git",
    "directory": "sdk/javascript"
  },
  "bin": {
    "tako-sh-gen-channel-types": "./dist/gen-channel-types.mjs",
    "tako-worker": "./dist/entrypoints/bun-worker.mjs"
  },
  "files": [
    "dist",
    "skills"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.mts",
      "import": "./dist/runtime.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.mts",
      "import": "./dist/nextjs.mjs"
    },
    "./internal": {
      "types": "./dist/internal.d.mts",
      "import": "./dist/internal.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@microsoft/fetch-event-source": "^2.0.1",
    "@sinclair/typebox": "^0.34.49"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@testing-library/react": "^16.1.0",
    "@tsconfig/strictest": "catalog:dev",
    "@types/bun": "catalog:dev",
    "@types/node": "catalog:dev",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "^0.22.0",
    "typescript": "catalog:dev",
    "vite": "catalog:dev"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
