---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const DEFAULT_AUTHOR = "Tako-kun";
const authors: Record<string, string> = {
  dan: "Dan Lilienblum",
};

const posts = await getCollection("blog");
const sorted = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<BaseLayout title="Tako Blog: Self-Hosted App Notes" description="Updates, ideas, and progress from the Tako project.">
  <section class="blog-list-sheet">
    <div class="blog-list-header">
      <h1 class="blog-list-title">Blog</h1>
      <p class="blog-list-subtitle">Notes from the deep</p>
    </div>
    {sorted.length === 0 && <p class="blog-empty">No posts yet.</p>}
    <div class="blog-posts">
      {sorted.map((post) => {
        const date = post.data.date
          ? new Date(post.data.date).toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })
          : "";
        const authorName = (post.data.author && authors[post.data.author]) ?? DEFAULT_AUTHOR;
        return (
          <a href={`/blog/${post.id}/`} class="blog-post-card">
            <div class="blog-post-body">
              <span class="blog-post-title">{post.data.title}</span>
              {post.data.description && (
                <span class="blog-post-desc">{post.data.description}</span>
              )}
              <div class="blog-post-meta">
                {date && <time class="blog-post-date" datetime={post.data.date}>{date}</time>}
                {date && authorName && <span class="blog-post-sep">&middot;</span>}
                {authorName && <span class="blog-post-author">{authorName}</span>}
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style is:global>
  .blog-list-sheet {
    border: 2px solid var(--line);
    border-radius: var(--panel-radius);
    background: var(--panel);
    box-shadow: 0 18px 45px rgba(47, 42, 68, 0.1);
    padding: clamp(18px, 4vw, 36px);
    margin: 0 auto;
  }

  .blog-list-header {
    margin-bottom: 24px;
    border-bottom: 2px solid var(--line);
    padding-bottom: 12px;
  }

  .blog-list-title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4.2vw, 36px);
    color: var(--ink);
    margin-bottom: 2px;
  }

  .blog-list-subtitle {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 13px;
    color: var(--muted);
    opacity: 0.7;
  }

  .blog-empty {
    color: var(--muted);
    font-size: 16px;
  }

  .blog-posts {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .blog-post-card {
    display: block;
    text-decoration: none;
    padding: 14px 16px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: color-mix(in oklch, var(--panel-strong) 70%, transparent);
    transition: border-color 0.15s, background 0.15s;
  }

  .blog-post-card:hover {
    border-color: rgba(232, 135, 131, 0.45);
    background: rgba(232, 135, 131, 0.08);
  }

  .blog-post-card:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .blog-post-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .blog-post-title {
    font-family: "Nunito", sans-serif;
    font-size: 17px;
    font-weight: 600;
    color: var(--ink);
  }

  .blog-post-desc {
    font-family: "Nunito", sans-serif;
    font-size: 14px;
    color: var(--muted);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-post-meta {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .blog-post-date {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 13px;
    color: var(--muted);
    white-space: nowrap;
  }

  .blog-post-sep {
    color: var(--muted);
    opacity: 0.4;
    font-size: 12px;
  }

  .blog-post-author {
    font-family: "Nunito", sans-serif;
    font-size: 13px;
    color: var(--muted);
    white-space: nowrap;
  }

</style>

<script is:inline>
  document.querySelectorAll('.blog-post-card').forEach(function(card) {
    card.addEventListener('click', function() {
      var title = card.querySelector('.blog-post-title')?.textContent?.trim();
      var href = card.getAttribute('href');
      window.posthog?.capture('blog_post_clicked', { title: title, href: href });
    });
  });
</script>
