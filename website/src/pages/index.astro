---
import BaseLayout from "../layouts/BaseLayout.astro";
import CopyButton from "../components/CopyButton.astro";
import HomeScripts from "../components/home/HomeScripts.astro";
import HomeStyles from "../components/home/HomeStyles.astro";
import HomeProductSections from "../components/home/HomeProductSections.astro";
import PerformanceResultsChart from "../components/home/PerformanceResultsChart.astro";
import ExternalLinkIcon from "lucide-astro/ExternalLink";

const homeStructuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Tako",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Linux",
  url: "https://tako.sh/",
  image: "https://tako.sh/assets/og.png",
  description: "Run apps on your own servers with local development, production deploys, routing, TLS, logs, secrets, and more.",
  softwareHelp: "https://tako.sh/docs/",
  downloadUrl: "https://tako.sh/install.sh",
  codeRepository: "https://github.com/tako-sh/tako",
  featureList: [
    "Local development with HTTPS and custom domains",
    "Production deploys with rolling updates",
    "Automatic TLS and request routing",
    "Logs, secrets, and server management",
    "Durable WebSocket and SSE channels",
    "Durable workflows with cron, waits, and retries",
    "Signed uploads and file storage",
    "App data backups",
    "Public image optimization",
  ],
};
---
<BaseLayout
  title="Run apps on your own servers - Tako"
  description="Deploy apps to your own servers with rolling deploys, TLS, health checks, logs, and secrets for Node.js, Bun, Go, and more."
  structuredData={homeStructuredData}
>
  <section class="hero">
    <div
      class="panel-hanger"
      id="mit-hanger"
      aria-label="License: MIT (includes Apache-2.0 dependencies)"
      title="Project code is MIT; some dependencies (for example Pingora) are Apache-2.0. See THIRD_PARTY_NOTICES.md."
    >
      <span class="panel-pin" id="mit-pin" aria-hidden="true"></span>
      <div class="panel-arm">
        <span class="panel-thread"></span>
        <div class="panel-tag" id="mit-tag">
          <span class="panel-tag-label">license</span>
          <span class="panel-tag-value">MIT</span>
        </div>
      </div>
    </div>
    <h1 class="title">Your app <span class="title-mid">belongs<br /> on</span> <span class="accent">your servers</span></h1>
    <p class="subtitle">
      The platform layer that makes them feel like a PaaS.
    </p>

    <div class="command-card">
      <div class="command-head">
        <span class="command-caption">install with one command</span>
      </div>
      <div class="command-body">
        <span class="prompt">$</span>
        <span class="cmd" id="typed-cmd">curl -fsSL https://tako.sh/install.sh | sh</span>
        <span class="cursor" aria-hidden="true"></span>
        <CopyButton variant="command" id="copy" ariaLabel="copy install command" title="copy install command" label="copy" />
      </div>
    </div>
    <div
      class="agent-prompt-card"
      aria-label="Prompt to copy into an agent"
    >
      <div class="agent-prompt-body">
        <div class="agent-prompt-copy">
          <span>ask Codex, Claude, or another agent</span>
          <p id="agent-prompt-text">Move this project to tako.sh.</p>
        </div>
        <CopyButton variant="agent" id="agent-copy" ariaLabel="copy agent prompt" title="copy agent prompt" label="copy" />
      </div>
    </div>
    <div class="hero-actions">
      <a class="btn btn-primary" href="/docs/quickstart/">get started</a>
      <a class="cta-link hero-actions-link hero-demo-link" href="https://demo.tako.sh" target="_blank" rel="noopener noreferrer">
        <span>live demo</span>
        <ExternalLinkIcon class="hero-demo-icon" aria-hidden="true" focusable="false" />
      </a>
      <a class="cta-link hero-actions-link" href="/docs/">or read the docs &rarr;</a>
    </div>
  </section>

  <section class="philosophy-section">
    <h2 class="philosophy-label">Takosophy</h2>
    <p class="philosophy-text">
      Full <strong class="accent-coral">control.</strong> A real server, a real runtime &mdash; what runs locally runs in production.
    </p>
    <p class="philosophy-text">
      Unapologetically <strong class="accent-mint">opinionated.</strong> No config rabbit holes &mdash; Tako picks the defaults so you can ship.
    </p>
    <p class="philosophy-text">
      Built for the <strong class="accent-gold">impatient.</strong> Every step is optimized to get your code live fast.
    </p>
  </section>

  <section class="workflow-section">
    <div class="hero-block-head">
      <h2 class="hero-block-label">Three commands and you're live</h2>
      <span class="hero-block-rule" aria-hidden="true"></span>
    </div>
    <ol class="workflow-steps">
      <li class="workflow-step">
        <a href="/docs/quickstart/" class="workflow-link">
          <span class="workflow-orb workflow-orb-1" aria-hidden="true">1</span>
          <code class="workflow-cmd">tako init</code>
          <p class="workflow-desc">Detect runtime, create config</p>
        </a>
      </li>
      <li class="workflow-step">
        <a href="/docs/development/" class="workflow-link">
          <span class="workflow-orb workflow-orb-2" aria-hidden="true">2</span>
          <code class="workflow-cmd">tako dev</code>
          <p class="workflow-desc">Develop locally with HTTPS</p>
        </a>
      </li>
      <li class="workflow-step">
        <a href="/docs/deployment/" class="workflow-link">
          <span class="workflow-orb workflow-orb-3" aria-hidden="true">3</span>
          <code class="workflow-cmd">tako deploy</code>
          <p class="workflow-desc">Build, upload, rolling update</p>
        </a>
      </li>
    </ol>
  </section>

  <HomeProductSections />

  <section class="performance-section">
    <div class="hero-block-head">
      <h2 class="hero-block-label">Ready for serious load</h2>
      <span class="hero-block-rule" aria-hidden="true"></span>
    </div>
    <div class="performance-body">
      <PerformanceResultsChart />
      <a href="/performance/" class="performance-link performance-chart-link">full report &rarr;</a>
      <div class="performance-copy">
        <p>
          Tako can handle <span class="performance-mark performance-traffic">heavy traffic</span> even on modest hardware: one small VM served 12.5k HTTPS 200 RPS at 5k concurrency, with <span class="performance-mark performance-clean">zero client errors</span> up to 20k concurrency.
          In the same public run, it outpaced <a href="https://caddyserver.com/" class="performance-reference-link" target="_blank" rel="noopener noreferrer nofollow">Caddy</a> and <a href="https://www.envoyproxy.io/" class="performance-reference-link" target="_blank" rel="noopener noreferrer nofollow">Envoy</a> under heavy HTTPS load.
        </p>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <p class="cta-text">Stop configuring.<br class="mobile-break"> Start shipping.</p>
    <div class="cta-actions">
      <a href="/docs/quickstart/" class="btn cta-btn">get started</a>
      <a href="/docs/how-tako-works/" class="cta-link">or read how Tako works &rarr;</a>
    </div>
  </section>
  <HomeStyles />
  <HomeScripts />
</BaseLayout>
