---
interface BlogPostLink {
  title: string;
  href: string;
}

export interface Props {
  previousPost?: BlogPostLink | undefined;
  nextPost?: BlogPostLink | undefined;
}

const previousPost = Astro.props.previousPost;
const nextPost = Astro.props.nextPost;
---
{(previousPost || nextPost) && (
  <nav class="blog-post-nav" aria-label="More blog posts">
    {previousPost ? (
      <a
        class="blog-post-nav-link blog-post-nav-prev"
        href={previousPost.href}
        aria-label={`Older post: ${previousPost.title}`}
        title={previousPost.title}
      >
        <span class="blog-post-nav-copy">
          <span class="blog-post-nav-kicker"><span aria-hidden="true">&larr;</span> Older post</span>
          <span class="blog-post-nav-title">{previousPost.title}</span>
        </span>
      </a>
    ) : <span class="blog-post-nav-spacer" aria-hidden="true"></span>}
    {nextPost ? (
      <a
        class="blog-post-nav-link blog-post-nav-next"
        href={nextPost.href}
        aria-label={`Newer post: ${nextPost.title}`}
        title={nextPost.title}
      >
        <span class="blog-post-nav-copy">
          <span class="blog-post-nav-kicker">Newer post <span aria-hidden="true">&rarr;</span></span>
          <span class="blog-post-nav-title">{nextPost.title}</span>
        </span>
      </a>
    ) : <span class="blog-post-nav-spacer" aria-hidden="true"></span>}
  </nav>
)}

<style>
  .blog-post-nav {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(20px, 5vw, 56px);
    border-top: 2px solid var(--line);
    margin-top: 38px;
    padding-top: 18px;
  }

  .blog-post-nav .blog-post-nav-link {
    min-width: 0;
    color: var(--ink);
    display: block;
    padding: 2px 0 4px;
    text-decoration: none;
    border-bottom: 0;
    transition:
      color 0.16s ease,
      text-decoration-color 0.16s ease;
  }

  .blog-post-nav .blog-post-nav-link:hover {
    border-bottom: 0;
    color: var(--primary-text);
  }

  .blog-post-nav .blog-post-nav-link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 3px;
  }

  .blog-post-nav-prev {
    justify-self: start;
  }

  .blog-post-nav-next {
    justify-self: end;
    text-align: right;
  }

  .blog-post-nav-copy {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .blog-post-nav-kicker {
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 800;
    line-height: 1.1;
  }

  .blog-post-nav-link:hover .blog-post-nav-kicker {
    color: var(--primary-text);
  }

  .blog-post-nav-title {
    min-width: 0;
    font-family: var(--font-sans);
    font-size: clamp(15px, 1.7vw, 17px);
    font-weight: 800;
    line-height: 1.22;
    color: currentColor;
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }

  .blog-post-nav-link:hover .blog-post-nav-title {
    text-decoration-color: currentColor;
  }

  .blog-post-nav-spacer {
    display: none;
  }

  @media (max-width: 720px) {
    .blog-post-nav {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .blog-post-nav-prev,
    .blog-post-nav-next {
      text-align: left;
      justify-self: stretch;
    }

    .blog-post-nav-next {
      padding-top: 18px;
      border-top: 1px solid var(--line);
    }

    .blog-post-nav-next .blog-post-nav-copy {
      text-align: left;
    }
  }
</style>
