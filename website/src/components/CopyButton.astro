---
import CheckIcon from "lucide-astro/Check";
import CopyIcon from "lucide-astro/Copy";

export interface Props {
  id?: string;
  variant?: "command" | "agent";
  class?: string;
  ariaLabel?: string;
  title?: string;
  label?: string;
}

const {
  id,
  variant = "command",
  class: className = "",
  ariaLabel = "Copy",
  title = "Copy",
  label = "",
} = Astro.props;

const variantClass = `copy-button--${variant}`;
---
<button id={id} class:list={["copy-button", variantClass, className]} type="button" aria-label={ariaLabel} title={title}>
  <CopyIcon class="copy-button-icon copy-button-icon-copy" aria-hidden="true" focusable="false" />
  <CheckIcon class="copy-button-icon copy-button-icon-check" aria-hidden="true" focusable="false" />
  {label && (
    <span class="copy-button-label" data-copy-label>
      {label}
    </span>
  )}
</button>
