<script is:inline>
			(function () {
				var hamburger = document.querySelector(".hamburger");
				var mobileMenu = document.getElementById("mobile-menu");
				if (!hamburger || !mobileMenu) return;
				hamburger.addEventListener("click", function (e) {
					e.stopPropagation();
					var isOpen = mobileMenu.classList.toggle("is-open");
					hamburger.classList.toggle("is-open");
					hamburger.setAttribute("aria-expanded", String(isOpen));
					if (isOpen) {
						mobileMenu.removeAttribute("inert");
					} else {
						mobileMenu.setAttribute("inert", "");
					}
				});
				document.addEventListener("click", function (e) {
					if (
						!mobileMenu.contains(e.target) &&
						!hamburger.contains(e.target)
					) {
						mobileMenu.classList.remove("is-open");
						hamburger.classList.remove("is-open");
						hamburger.setAttribute("aria-expanded", "false");
						mobileMenu.setAttribute("inert", "");
					}
				});
			})();
		</script>
		<script is:inline>
			(function () {
				var footer = document.querySelector(".site-footer");
				if (!footer) return;
				var prefersReducedMotion = window.matchMedia(
					"(prefers-reduced-motion: reduce)",
				).matches;
				if (prefersReducedMotion) {
					footer.classList.add("is-footer-story-visible");
					return;
				}
				footer.classList.add("is-footer-story-ready");
				var target = footer.querySelector(".footer-story") || footer;
				if (typeof IntersectionObserver === "undefined") {
					window.requestAnimationFrame(function () {
						footer.classList.add("is-footer-story-visible");
					});
					return;
				}
				var io = new IntersectionObserver(
					function (entries) {
						if (!entries[0].isIntersecting) return;
						footer.classList.add("is-footer-story-visible");
						io.disconnect();
					},
					{
						rootMargin: "0px 0px 20% 0px",
						threshold: 0.01,
					},
				);
				io.observe(target);
			})();
		</script>
		<script is:inline>
			(function () {
				var sentinel = document.querySelector(".header-sentinel");
				var header = document.querySelector(".header");
				if (
					!sentinel ||
					!header ||
					typeof IntersectionObserver === "undefined"
				)
					return;
				var io = new IntersectionObserver(function (entries) {
					header.classList.toggle(
						"is-scrolled",
						!entries[0].isIntersecting,
					);
				});
				io.observe(sentinel);
			})();
		</script>
		<script is:inline>
			(function () {
				var el = document.getElementById("logo-text");
				if (!el) return;
				if (window.location.pathname !== "/") {
					el.textContent = "tako";
					el.style.fontFamily = '"Nunito", sans-serif';
					return;
				}
				var mono = '"IBM Plex Mono", monospace';
				var sans = '"Nunito", sans-serif';
				function rbit() {
					return Math.random() > 0.5 ? "1" : "0";
				}

				// Phase 1: show たこ for 700ms
				el.textContent = "たこ";
				setTimeout(function () {
					// Phase 2: clean swap to binary
					el.style.fontFamily = mono;
					var b = "";
					for (var j = 0; j < 4; j++) b += rbit();
					el.textContent = b;
					// Brief scramble
					var s = 0;
					var scramble = setInterval(function () {
						var b = "";
						for (var j = 0; j < 4; j++) b += rbit();
						el.textContent = b;
						s++;
						if (s >= 6) {
							clearInterval(scramble);
							// Phase 3: binary → tako, letter by letter
							var cur = el.textContent;
							var k = 0;
							var toTako = setInterval(function () {
								cur = "tako".slice(0, k + 1) + cur.slice(k + 1);
								el.textContent = cur;
								if (k === 0) {
									el.style.fontFamily = sans;
								}
								k++;
								if (k >= 4) {
									clearInterval(toTako);
								}
							}, 150);
						}
					}, 70);
				}, 700);
			})();
		</script>
		<script is:inline>
			(function () {
				document
					.querySelectorAll('a[href*="github.com"]')
					.forEach(function (link) {
						link.addEventListener("click", function () {
							window.posthog?.capture("github_clicked", {
								href: link.getAttribute("href"),
								location: link.closest("header")
									? "header"
									: "footer",
							});
						});
					});
				document
					.querySelectorAll('a[href*="discord.gg/"]')
					.forEach(function (link) {
						link.addEventListener("click", function () {
							window.posthog?.capture("discord_clicked", {
								href: link.getAttribute("href"),
								location: link.closest("header")
									? "header"
									: "footer",
							});
						});
					});
			})();
		</script>
		<script is:inline>
			(function () {
				if (
					!("navigator" in window) ||
					!navigator.modelContext ||
					typeof navigator.modelContext.provideContext !== "function"
				)
					return;
				var DOC_PAGES = [
					"quickstart",
					"cli",
					"deployment",
					"development",
					"troubleshooting",
					"how-tako-works",
					"tako-toml",
					"framework-guides",
					"presets",
				];
				var GETTING_STARTED =
					"1. Install the CLI:  curl -fsSL https://tako.sh/install.sh | sh\n" +
					"2. Scaffold a project:  tako init\n" +
					"3. Run the dev loop:  tako dev";
				var INSTALL = {
					cli: "curl -fsSL https://tako.sh/install.sh | sh",
					server: "curl -fsSL https://tako.sh/install-server.sh | sudo sh",
				};
				try {
					navigator.modelContext.provideContext({
						tools: [
							{
								name: "navigateToDocs",
								description:
									"Navigate the current tab to a tako.sh documentation page.",
								inputSchema: {
									type: "object",
									properties: {
										page: {
											type: "string",
											enum: DOC_PAGES,
											description:
												"Doc slug under /docs/.",
										},
									},
									required: ["page"],
								},
								execute: function (input) {
									window.location.assign(
										"/docs/" + input.page + "/",
									);
									return "Navigating to /docs/" + input.page + "/";
								},
							},
							{
								name: "searchDocs",
								description:
									"Search the tako.sh docs. Opens /docs with the query in the URL.",
								inputSchema: {
									type: "object",
									properties: {
										query: {
											type: "string",
											minLength: 1,
											description:
												"Free-text search query.",
										},
									},
									required: ["query"],
								},
								execute: function (input) {
									var q = encodeURIComponent(
										String(input.query).slice(0, 256),
									);
									window.location.assign("/docs/?q=" + q);
									return (
										'Opened docs with query "' +
										input.query +
										'".'
									);
								},
							},
							{
								name: "getStartedCommand",
								description:
									"Return the three-step tako.sh getting-started commands as plain text.",
								inputSchema: { type: "object", properties: {} },
								execute: function () {
									return GETTING_STARTED;
								},
							},
							{
								name: "getInstallCommand",
								description:
									"Return the one-line curl install command for the tako CLI or the tako server.",
								inputSchema: {
									type: "object",
									properties: {
										kind: {
											type: "string",
											enum: ["cli", "server"],
										},
									},
									required: ["kind"],
								},
								execute: function (input) {
									return INSTALL[input.kind];
								},
							},
						],
					});
				} catch (_e) {
					/* ignore */
				}
			})();
		</script>
