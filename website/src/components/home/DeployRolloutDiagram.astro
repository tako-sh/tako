  viewBox="0 0 520 248"
  role="img"
  aria-labelledby="deploy-cloud-title deploy-cloud-desc"
  focusable="false"
>
  <title id="deploy-cloud-title">Tako deploy targets</title>
  <desc id="deploy-cloud-desc">
    One Tako deploy command branches to VPS targets in AWS Tokyo, Vultr
    Amsterdam, and Hetzner Ashburn.
  </desc>

  <defs>
    <path id="deploy-branch-aws" d="M 260 92 C 220 112 142 114 93 145" />
    <path id="deploy-branch-vultr" d="M 260 92 C 260 112 260 124 260 145" />
    <path id="deploy-branch-hetzner" d="M 260 92 C 300 112 378 114 427 145" />
  </defs>

  <g class="deploy-command-card">
    <rect x="154" y="20" width="212" height="62" rx="4" />
    <text x="260" y="58" class="deploy-command-text">
      <tspan class="deploy-prompt">$</tspan>
      <tspan>tako deploy</tspan>
    </text>
  </g>

  <g class="deploy-branches" aria-hidden="true">
    <path class="deploy-trunk" d="M 260 82 V 92" />
    <use href="#deploy-branch-aws" class="deploy-edge deploy-edge-aws" />
    <use href="#deploy-branch-vultr" class="deploy-edge deploy-edge-vultr" />
    <use href="#deploy-branch-hetzner" class="deploy-edge deploy-edge-hetzner" />
  </g>

  <g class="deploy-target deploy-target-aws">
    <rect x="18" y="145" width="150" height="82" rx="16" />
