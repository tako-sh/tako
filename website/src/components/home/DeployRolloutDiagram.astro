    <text x="42" y="197" class="deploy-region">ap-northeast-1</text>
    <text x="42" y="216" class="deploy-city">Tokyo</text>
  </g>

  <g class="deploy-target deploy-target-vultr">
    <rect x="185" y="145" width="150" height="82" rx="16" />
    <text x="209" y="174" class="deploy-provider">Vultr</text>
    <text x="209" y="197" class="deploy-region">ams</text>
    <text x="209" y="216" class="deploy-city">Amsterdam</text>
  </g>

  <g class="deploy-target deploy-target-hetzner">
    <rect x="352" y="145" width="150" height="82" rx="16" />
    <text x="376" y="174" class="deploy-provider">Hetzner</text>
    <text x="376" y="197" class="deploy-region">us-east</text>
    <text x="376" y="216" class="deploy-city">Ashburn, VA</text>
  </g>
