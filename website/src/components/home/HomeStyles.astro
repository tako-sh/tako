<style is:global>
  .hero {
    border-radius: var(--panel-radius);
    border: 2px solid var(--line);
    background: var(--panel);
    box-shadow: 0 18px 45px rgba(47, 42, 68, 0.1);
    padding: clamp(24px, 5vw, 54px);
    overflow: visible;
    position: relative;
    isolation: isolate;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background:
      radial-gradient(ellipse at 85% 25%, rgba(155, 196, 182, 0.16) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 75%, rgba(232, 135, 131, 0.14) 0%, transparent 45%),
      radial-gradient(ellipse at 95% 60%, rgba(214, 166, 62, 0.10) 0%, transparent 40%),
      radial-gradient(ellipse at 30% 45%, rgba(232, 135, 131, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 55% 80%, rgba(155, 196, 182, 0.10) 0%, transparent 50%),
      radial-gradient(ellipse at 20% 65%, rgba(214, 166, 62, 0.055) 0%, transparent 45%);
    z-index: 0;
    pointer-events: none;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 1024 1024' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.09;
    mix-blend-mode: overlay;
    pointer-events: none;
    z-index: 1;
  }

  .hero > *:not(.panel-hanger) {
    position: relative;
    z-index: 2;
  }

  .panel-hanger {
    position: absolute;
    top: 26px;
    right: 10px;
    width: 164px;
    height: 152px;
    z-index: 12;
    --swing-angle: 0.17rad;
    --thread-length: 48px;
    --card-tilt: -0.06rad;
    --hanger-axis: 112px;
  }

  .panel-pin {
    position: absolute;
    top: 10px;
    left: calc(var(--hanger-axis) - 5px);
    width: 10px;
    height: 10px;
    border: 2px solid rgba(47, 42, 68, 0.28);
    border-radius: 50%;
    background: var(--secondary);
    box-shadow: 0 2px 0 rgba(47, 42, 68, 0.15);
  }

  .panel-arm {
    position: absolute;
    top: 16px;
    left: var(--hanger-axis);
    width: 0;
    transform-origin: top center;
    transform: rotate(var(--swing-angle));
    pointer-events: none;
  }

  .panel-thread {
    display: block;
    width: 2px;
    margin-left: -1px;
    height: var(--thread-length);
    background: rgba(47, 42, 68, 0.45);
  }

  .panel-tag {
    position: absolute;
    left: 0;
    top: var(--thread-length);
    transform: translateX(-50%) rotate(var(--card-tilt));
    transform-origin: top center;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    width: 86px;
    border: 2px solid rgba(47, 42, 68, 0.26);
    border-radius: 12px 12px 16px 16px;
    background: linear-gradient(160deg, var(--panel-strong), var(--panel));
    box-shadow: 0 8px 14px rgba(47, 42, 68, 0.16);
    padding: 8px 10px 10px;
    font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 12px;
    color: rgba(47, 42, 68, 0.86);
    text-align: center;
    z-index: 1;
    pointer-events: auto;
    cursor: grab;
    touch-action: none;
    user-select: none;
  }

  .panel-tag-label {
    display: block;
    font-size: 11px;
    letter-spacing: 0.1em;
    line-height: 1;
    opacity: 0.82;
    text-transform: uppercase;
  }

  .panel-tag-value {
    display: block;
    margin-top: 2px;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    color: var(--primary-text);
  }

  .title {
    font-family: var(--font-heading);
    font-size: clamp(38px, 8vw, 72px);
    line-height: 1;
    letter-spacing: 0.01em;
    margin-bottom: 14px;
  }

  .title .accent {
    color: var(--accent);
  }

  .subtitle {
    max-width: 680px;
    font-size: clamp(18px, 2.8vw, 26px);
    line-height: 1.25;
    color: var(--muted);
    margin-bottom: 24px;
  }

  .command-card {
    border: 2px solid rgba(47, 42, 68, 0.2);
    border-radius: 18px;
    background: var(--paper);
    overflow: hidden;
    max-width: 640px;
  }

  .command-head {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    position: relative;
    background: var(--mint-soft);
    border-bottom: 1.5px solid rgba(47, 42, 68, 0.1);
    padding: 7px 14px;
  }

  .command-caption {
    font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: rgba(47, 42, 68, 0.6);
  }

  .command-body {
    font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: clamp(14px, 2.1vw, 18px);
    padding: 14px 14px 14px 16px;
    display: flex;
    flex-wrap: nowrap;
    gap: 10px;
    align-items: center;
    justify-content: flex-start;
    overflow-x: auto;
  }

  .prompt {
    color: var(--primary-text);
  }

  .cmd {
    color: var(--ink);
    min-height: 1.2em;
    white-space: nowrap;
    flex: 0 0 auto;
  }

  .cursor {
    width: 8px;
    height: 18px;
    background: var(--ink);
    animation: blink 1s steps(1, end) infinite;
    flex: 0 0 auto;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 10px 12px;
    flex-wrap: wrap;
    margin-top: 18px;
  }

  .hero-actions-link {
    font-size: 15px;
  }

  .hero-demo-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-height: 45px;
    padding: 0 18px;
    border: 1.5px solid rgba(47, 42, 68, 0.18);
    border-radius: 999px;
    background: var(--panel-glass);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--panel-strong) 72%, transparent);
    font-weight: 700;
    opacity: 1;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }

  .hero-demo-link:hover {
    transform: translateY(-1px);
    border-color: rgba(155, 196, 182, 0.72);
    background: rgba(219, 235, 230, 0.62);
    color: var(--ink);
    box-shadow: 0 5px 14px rgba(80, 113, 102, 0.14);
  }

  .hero-demo-icon {
    width: 0.95em;
    height: 0.95em;
    stroke-width: 2.4;
  }

  .btn {
    border: 1.5px solid rgba(232, 135, 131, 0.4);
    border-radius: 999px;
    background: rgba(232, 135, 131, 0.2);
    color: var(--ink);
    padding: 8px 18px;
    font-family: "Nunito", sans-serif;
    font-size: 16px;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }

  .btn:hover {
    transform: translateY(-1px);
    background: rgba(232, 135, 131, 0.32);
    border-color: rgba(232, 135, 131, 0.55);
  }

  .btn-primary {
    border-color: var(--primary);
    background: var(--primary);
    color: var(--ink);
    padding: 12px 26px;
    font-size: 17px;
    box-shadow: 0 6px 16px rgba(196, 96, 92, 0.22);
  }

  .btn-primary:hover {
    background: color-mix(in srgb, var(--primary) 92%, var(--ink));
    border-color: color-mix(in srgb, var(--primary) 92%, var(--ink));
    box-shadow: 0 8px 20px rgba(196, 96, 92, 0.28);
  }

  .btn:focus-visible,
  .copy-inline:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .copy-inline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 40px;
    margin-left: auto;
    padding: 0 14px 0 38px;
    border: 1.5px solid rgba(232, 135, 131, 0.45);
    border-radius: 999px;
    background: rgba(232, 135, 131, 0.14);
    color: var(--primary-text);
    font-family: "Nunito", sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
    cursor: pointer;
    flex: 0 0 auto;
    transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }

  .copy-inline:hover {
    transform: translateY(-1px);
    background: rgba(232, 135, 131, 0.22);
    border-color: rgba(232, 135, 131, 0.6);
  }

  .copy-inline .copy-button-icon {
    width: 15px;
    height: 15px;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
  }

  .copy-inline.is-copied .copy-button-icon-copy {
    transform: translateY(-50%) scale(0.85);
  }

  .copy-inline .copy-button-icon-check {
    transform: translateY(-50%) scale(0.85);
  }

  .copy-inline.is-copied .copy-button-icon-check {
    transform: translateY(-50%) scale(1);
  }

  .copy-inline .copy-button-label {
    position: static;
    width: auto;
    height: auto;
    margin: 0;
    padding: 0;
    overflow: visible;
    clip: auto;
    border: 0;
    text-transform: lowercase;
  }

  .copy-inline.is-copied {
    background: rgba(155, 196, 182, 0.28);
    border-color: rgba(155, 196, 182, 0.6);
    color: rgba(22, 110, 80, 0.95);
  }

  /* Shared section header */
  .hero-block-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }

  .hero-block-label {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: rgba(47, 42, 68, 0.9);
  }

  .hero-block-rule {
    flex: 1;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(232, 135, 131, 0.35), rgba(155, 196, 182, 0.25), transparent);
  }

  /* Workflow section */
  .workflow-section {
    margin-top: clamp(44px, 6vw, 58px);
  }

  .workflow-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    list-style: none;
    padding: 0;
  }

  .workflow-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 4px;
    padding: 24px 20px;
    text-decoration: none;
    border-radius: 20px;
    transition: background 0.15s ease;
  }

  .workflow-step:nth-child(1) .workflow-link { background: rgba(232, 135, 131, 0.06); }
  .workflow-step:nth-child(2) .workflow-link { background: rgba(155, 196, 182, 0.07); }
  .workflow-step:nth-child(3) .workflow-link { background: rgba(214, 166, 62, 0.06); }

  .workflow-orb {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 700;
    color: white;
    box-shadow: 0 2px 6px rgba(47, 42, 68, 0.15);
    margin-bottom: 12px;
  }

  .workflow-orb-1 { background: var(--primary); }
  .workflow-orb-2 { background: var(--secondary); }
  .workflow-orb-3 { background: var(--gold); }

  .workflow-link:hover {
    background: rgba(47, 42, 68, 0.06);
  }

  .workflow-link:hover .workflow-cmd {
    color: var(--accent);
  }


  .workflow-link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
    border-radius: 14px;
  }

  .workflow-cmd {
    font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
    background: none;
    padding: 0;
    transition: color 0.15s ease;
  }

  .workflow-desc {
    font-size: 14px;
    line-height: 1.35;
    color: var(--muted);
  }

  .cta-link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  /* Philosophy statement */
  .philosophy-section {
    margin-top: clamp(44px, 6vw, 58px);
  }

  .philosophy-label {
    font-family: "Caveat", cursive;
    font-weight: 500;
    font-size: clamp(30px, 5vw, 44px);
    line-height: 1;
    letter-spacing: 0.01em;
    color: var(--accent);
    margin-bottom: 14px;
    display: inline-block;
    transform: rotate(-1deg);
    transform-origin: left center;
  }

  .philosophy-text {
    font-family: var(--font-heading);
    font-size: clamp(20px, 3.5vw, 28px);
    font-weight: 600;
    line-height: 1.3;
    color: var(--muted);
  }

  .philosophy-text + .philosophy-text {
    margin-top: 24px;
  }

  .philosophy-text .accent-coral,
  .philosophy-text .accent-mint,
  .philosophy-text .accent-gold {
    color: var(--ink);
    padding: 1px 5px 2px;
    margin: 0 -1px;
    border-radius: 2px;
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
  }

  .philosophy-text .accent-coral {
    background: rgba(232, 135, 131, 0.22);
  }

  .philosophy-text .accent-mint {
    background: rgba(155, 196, 182, 0.3);
  }

  .philosophy-text .accent-gold {
    background: rgba(214, 166, 62, 0.22);
  }

  .features-subcopy {
    max-width: 640px;
    margin: -4px 0 16px;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.45;
  }

  /* Included pills (inside features section) */

  .included-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .included-tag {
    font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 13px;
    padding: 7px 14px;
    border-radius: 999px;
    border: 1.5px solid rgba(47, 42, 68, 0.12);
    background: none;
    color: rgba(47, 42, 68, 0.72);
    white-space: nowrap;
    cursor: pointer;
    transition: border-color 0.25s ease, background 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
  }

  .included-tag:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(47, 42, 68, 0.1);
  }

  .included-tag:active {
    transform: translateY(0.5px);
    box-shadow: none;
  }

  .included-tag:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .included-tag.is-active {
    transform: translateY(-1px);
    box-shadow: 0 3px 10px rgba(47, 42, 68, 0.15);
  }

  .feature-link.is-muted {
    display: none;
  }

  .included-tag:nth-child(4n+1) {
    border-color: rgba(232, 135, 131, 0.35);
  }
  .included-tag:nth-child(4n+1):hover {
    border-color: rgba(232, 135, 131, 0.5);
  }
  .included-tag:nth-child(4n+1).is-active {
    border-color: rgba(232, 135, 131, 0.5);
    background: rgba(232, 135, 131, 0.16);
  }

  .included-tag:nth-child(4n+2) {
    border-color: rgba(155, 196, 182, 0.4);
  }
  .included-tag:nth-child(4n+2):hover {
    border-color: rgba(155, 196, 182, 0.55);
  }
  .included-tag:nth-child(4n+2).is-active {
    border-color: rgba(155, 196, 182, 0.55);
    background: rgba(155, 196, 182, 0.18);
  }

  .included-tag:nth-child(4n+3) {
    border-color: rgba(214, 166, 62, 0.35);
  }
  .included-tag:nth-child(4n+3):hover {
    border-color: rgba(214, 166, 62, 0.5);
  }
  .included-tag:nth-child(4n+3).is-active {
    border-color: rgba(214, 166, 62, 0.5);
    background: rgba(214, 166, 62, 0.16);
  }

  .included-tag:nth-child(4n+4) {
    border-color: rgba(47, 42, 68, 0.2);
  }
  .included-tag:nth-child(4n+4):hover {
    border-color: rgba(47, 42, 68, 0.35);
  }
  .included-tag:nth-child(4n+4).is-active {
    border-color: rgba(47, 42, 68, 0.35);
    background: rgba(47, 42, 68, 0.08);
  }

  /* Features section */
  .features-section {
    margin-top: clamp(44px, 6vw, 58px);
  }

  .performance-section {
    margin-top: clamp(44px, 6vw, 58px);
    padding: clamp(18px, 3vw, 30px) 0;
  }

  .performance-copy {
    width: 100%;
  }

  .performance-copy p {
    max-width: 1040px;
    margin: 0;
    color: var(--muted);
    font-size: clamp(18px, 2.6vw, 24px);
    font-weight: 700;
    line-height: 1.34;
  }

  .performance-link {
    display: inline;
    color: var(--ink);
    font-weight: 800;
    text-decoration: underline;
    text-decoration-color: rgba(232, 135, 131, 0.62);
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    white-space: nowrap;
    transition: color 0.15s ease, text-decoration-color 0.15s ease;
  }

  .performance-link:hover {
    color: var(--accent);
    text-decoration-color: currentColor;
  }

  .performance-mark {
    display: inline;
    position: relative;
    isolation: isolate;
    color: var(--ink);
    font-weight: 900;
    padding: 0 0.16em 0.06em;
    margin: 0 -0.06em;
    border-radius: 2px;
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
  }

  .performance-traffic {
    background: linear-gradient(to top, rgba(232, 135, 131, 0.28) 0 42%, transparent 42%);
  }

  .performance-clean {
    background: linear-gradient(to top, color-mix(in srgb, var(--secondary) 42%, transparent) 0 42%, transparent 42%);
  }

  .performance-copy a.performance-reference-link,
  .performance-copy a.performance-reference-link:visited {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: rgba(232, 135, 131, 0.48);
    text-decoration-thickness: 1.5px;
    text-underline-offset: 3px;
    transition: color 0.15s ease, text-decoration-color 0.15s ease;
  }

  .performance-copy a.performance-reference-link:hover {
    color: var(--accent);
    text-decoration-color: currentColor;
  }

  .feature-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
  }

  .feature-show-all {
    display: none;
  }

  @keyframes feature-reveal {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .feature-link {
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-decoration: none;
    padding: 14px 16px;
    min-height: 76px;
    border-radius: 14px;
    transition: background 0.25s ease;
  }

  .feature-link:hover {
    background: rgba(232, 135, 131, 0.08);
  }

  .feature-link:hover .feature-link-title {
    color: var(--accent);
  }

  .feature-link-soon {
    opacity: 0.5;
    cursor: default;
  }

  .feature-link-soon:hover {
    background: none;
  }

  .feature-link-soon:hover .feature-link-title {
    color: var(--ink);
  }

  .soon-badge,
  .new-badge {
    display: inline-block;
    font-family: "Caveat", cursive;
    font-size: 18px;
    font-weight: 500;
    line-height: 1;
    vertical-align: baseline;
    margin-left: 4px;
  }

  .soon-badge {
    color: var(--primary-text);
  }

  .new-badge {
    color: var(--accent);
  }

  .feature-link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .feature-link-title {
    display: block;
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.2;
    transition: color 0.15s ease;
  }

  .feature-link-desc {
    display: block;
    font-size: 14px;
    line-height: 1.35;
    color: var(--muted);
    margin-top: 2px;
  }

  .feature-link-desc code {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 0.9em;
    padding: 1px 4px;
    border-radius: 4px;
    background: rgba(47, 42, 68, 0.06);
    color: var(--ink);
  }

  /* CTA section */
  .cta-section {
    margin-top: clamp(44px, 6vw, 58px);
    text-align: center;
    padding: 56px 0 28px;
    background:
      radial-gradient(ellipse at 45% 50%, rgba(232, 135, 131, 0.20) 0%, transparent 55%),
      radial-gradient(ellipse at 55% 50%, rgba(155, 196, 182, 0.17) 0%, transparent 55%);
  }

  .cta-text {
    font-family: var(--font-heading);
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 20px;
  }

  .cta-text .mobile-break {
    display: none;
  }

  @media (max-width: 480px) {
    .cta-text .mobile-break {
      display: block;
    }
  }

  .cta-actions {
    display: flex;
    align-items: center;
