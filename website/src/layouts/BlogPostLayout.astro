---
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import { createCanonicalUrl, normalizeCanonicalPath } from "../utils/canonical";
import { BLOG_IMAGE_DIMENSIONS } from "../utils/blog-image-dimensions";

const authors: Record<string, { name: string; link: string }> = {
  dan: { name: "Dan Lilienblum", link: "https://x.com/lilienblum" },
};

const defaultAuthor = { name: "Tako-kun", link: "/" };

export interface Props {
  title: string;
  date: string;
  author?: string | undefined;
  image?: string | undefined;
  imageAlt?: string | undefined;
  description?: string | undefined;
}

const title = Astro.props.title ?? "Tako Blog";
const date = Astro.props.date ?? "";
const authorId = Astro.props.author ?? "";
const { name: author, link: authorLink } = authors[authorId] ?? defaultAuthor;
const rawImage = Astro.props.image ?? "";
const image = rawImage ? `/assets/blog/${rawImage}.avif` : "";
const imageDimensions = rawImage ? BLOG_IMAGE_DIMENSIONS[rawImage] : undefined;
const imageAlt = Astro.props.imageAlt ?? title;
const description = Astro.props.description ?? title;
const slug = normalizeCanonicalPath(Astro.url.pathname).replace(/\/$/, "").replace(/^\/blog\//, "").replace(/^\//, "");
const ogPath = `/assets/blog/og/${slug}.png`;
const ogImage = new URL(ogPath, Astro.site).href;
const canonicalURL = createCanonicalUrl(Astro.url.pathname, Astro.site).href;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  image: ogImage,
  datePublished: date || undefined,
  author: {
    "@type": "Person",
    name: author,
    ...(authorLink && authorLink !== "/" ? { url: authorLink } : {}),
  },
  publisher: {
    "@type": "Organization",
    name: "Tako",
    url: "https://tako.sh",
    logo: { "@type": "ImageObject", url: "https://tako.sh/assets/og.png" },
  },
  url: canonicalURL,
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL },
});

const formatted = date
  ? new Date(date).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";

if (rawImage && !imageDimensions) {
  throw new Error(`Missing blog image dimensions for ${rawImage}`);
}
---
<BaseLayout title={`${title} - Tako Blog`} description={description} image={ogImage} type="article">
  {date && <meta slot="head" property="article:published_time" content={date} />}
  {author && <meta slot="head" property="article:author" content={author} />}
  <script is:inline slot="head" type="application/ld+json" set:html={jsonLd} />
  <section class={`blog-sheet ${image ? "has-hero" : ""}`}>
    {image && imageDimensions && (
      <div class="blog-hero">
        <Image
          src={image}
          alt={imageAlt}
          width={imageDimensions.width}
          height={imageDimensions.height}
          loading="eager"
          fetchpriority="high"
        />
      </div>
    )}
    <div class="blog-top">
      <a href="/blog" class="blog-back">&larr; back</a>
    </div>
    <article class="blog-article content">
      <header class="blog-header">
        <h1>{title}</h1>
        <div class="blog-meta">
          {authorLink
            ? <a href={authorLink} target="_blank" rel="noopener noreferrer" class="blog-author">{author}</a>
            : <span class="blog-author">{author}</span>
          }
          {formatted && <span class="blog-meta-sep">&middot;</span>}
          {formatted && <time class="blog-date" datetime={date}>{formatted}</time>}
        </div>
      </header>
      <slot />
    </article>
  </section>
</BaseLayout>

<script is:inline>
  (function() {
    var article = document.querySelector(".blog-article");
    if (!article) return;
    var headings = article.querySelectorAll("h2[id], h3[id], h4[id], h5[id], h6[id]");
    for (var i = 0; i < headings.length; i++) {
      var h = headings[i];
      var id = h.getAttribute("id");
      if (!id || h.querySelector(".heading-anchor")) continue;
      var a = document.createElement("a");
      a.className = "heading-anchor";
      a.href = "#" + id;
      a.textContent = "#";
      a.setAttribute("aria-hidden", "true");
      h.append(a);
      h.style.cursor = "pointer";
      h.addEventListener("click", (function(id) {
        return function(e) {
          if (e.target.closest("a") || window.getSelection().toString()) return;
          window.location.hash = id;
        };
      })(id));
    }
    var tables = article.querySelectorAll("table");
    for (var j = 0; j < tables.length; j++) {
      var wrap = document.createElement("div");
      wrap.className = "table-scroll";
      tables[j].parentNode.insertBefore(wrap, tables[j]);
      wrap.appendChild(tables[j]);
    }

    var diagrams = article.querySelectorAll('img[src^="/d2/"]');
    for (var k = 0; k < diagrams.length; k++) {
      enhanceDiagram(diagrams[k]);
    }

    function enhanceDiagram(img) {
      if (!img.parentNode || img.closest(".diagram-shell")) return;

      var shell = document.createElement("figure");
      shell.className = "diagram-shell";

      var viewport = document.createElement("div");
      viewport.className = "diagram-viewport";

      var canvas = document.createElement("div");
      canvas.className = "diagram-canvas";

      img.parentNode.insertBefore(shell, img);
      shell.appendChild(viewport);
      viewport.appendChild(canvas);
      canvas.appendChild(img);

      img.classList.add("diagram-image");
      img.draggable = false;

      img.addEventListener("click", function() {
        openLightbox(img);
      });
    }

    function openLightbox(sourceImg) {
      var existing = document.querySelector(".diagram-lightbox");
      if (existing) existing.close();

      var shell = document.createElement("dialog");
      shell.className = "diagram-lightbox";
      shell.setAttribute("aria-label", sourceImg.alt || "Diagram viewer");
      shell.tabIndex = -1;

      var panel = document.createElement("div");
      panel.className = "diagram-lightbox-panel";

      var toolbar = document.createElement("div");
      toolbar.className = "diagram-lightbox-toolbar";

      var zoomOut = makeLightboxButton(iconMinus(), "Zoom out");
      var zoomIn = makeLightboxButton(iconPlus(), "Zoom in");
      var close = makeLightboxButton(iconClose(), "Close viewer");
      close.classList.add("diagram-lightbox-close");

      toolbar.appendChild(zoomOut);
      toolbar.appendChild(zoomIn);
      toolbar.appendChild(close);

      var viewport = document.createElement("div");
      viewport.className = "diagram-lightbox-viewport";

      var canvas = document.createElement("div");
      canvas.className = "diagram-lightbox-canvas";

      var clone = sourceImg.cloneNode();
      clone.className = "diagram-lightbox-image";
      clone.draggable = false;

      shell.appendChild(panel);
      panel.appendChild(toolbar);
      panel.appendChild(viewport);
      viewport.appendChild(canvas);
      canvas.appendChild(clone);
      document.body.appendChild(shell);

      var naturalWidth = Number(sourceImg.getAttribute("width")) || sourceImg.naturalWidth || 0;
      var naturalHeight = Number(sourceImg.getAttribute("height")) || sourceImg.naturalHeight || 0;
      var zoom = 1;
      var minZoom = 1;
      var maxZoom = 5;
      var isClosing = false;
      var isDragging = false;
      var dragStartX = 0;
      var dragStartY = 0;
      var dragScrollLeft = 0;
      var dragScrollTop = 0;

      function makeLightboxButton(icon, title) {
        var button = document.createElement("button");
        button.type = "button";
        button.className = "diagram-button";
        button.innerHTML = icon;
        button.setAttribute("aria-label", title);
        button.title = title;
        return button;
      }

      function iconPlus() {
        return '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg>';
      }

      function iconMinus() {
        return '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14"></path></svg>';
      }

      function iconClose() {
        return '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>';
      }

      function clamp(value, min, max) {
        return Math.min(max, Math.max(min, value));
      }

      function updateBaseZoom() {
        var width = Math.max(1, viewport.clientWidth - 24);
        var height = Math.max(1, viewport.clientHeight - 24);
        if (!naturalWidth) naturalWidth = clone.naturalWidth || width;
        if (!naturalHeight) naturalHeight = clone.naturalHeight || height;
        minZoom = Math.min(1, width / naturalWidth, height / naturalHeight);
      }

      function updateButtons() {
        zoomOut.disabled = zoom <= minZoom;
        zoomIn.disabled = zoom >= maxZoom;
      }

      function applyZoom(nextZoom, keepCenter) {
        updateBaseZoom();
        var oldWidth = clone.getBoundingClientRect().width || naturalWidth;
        var oldHeight = clone.getBoundingClientRect().height || naturalHeight;
        var centerX = viewport.scrollLeft + viewport.clientWidth / 2;
        var centerY = viewport.scrollTop + viewport.clientHeight / 2;

        zoom = clamp(nextZoom, minZoom, maxZoom);
        clone.style.width = Math.round(naturalWidth * zoom) + "px";

        if (keepCenter && oldWidth > 0 && oldHeight > 0) {
          requestAnimationFrame(function() {
            var newWidth = clone.getBoundingClientRect().width || oldWidth;
            var newHeight = clone.getBoundingClientRect().height || oldHeight;
            viewport.scrollLeft = Math.max(0, centerX * (newWidth / oldWidth) - viewport.clientWidth / 2);
            viewport.scrollTop = Math.max(0, centerY * (newHeight / oldHeight) - viewport.clientHeight / 2);
            updateButtons();
          });
        } else {
          viewport.scrollLeft = 0;
          viewport.scrollTop = 0;
          updateButtons();
        }
      }

      async function closeLightbox() {
        if (isClosing) return;
        isClosing = true;
        isDragging = false;
        shell.classList.remove("is-dragging");
        document.removeEventListener("keydown", onKeydown);
        shell.removeEventListener("cancel", onCancel);
        shell.removeEventListener("click", onDialogClick);

        var prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        shell.classList.remove("is-open");
        shell.classList.add("is-closing");

        var animations = [];
        if (!prefersReducedMotion && typeof panel.animate === "function") {
          animations.push(panel.animate(
            [
              { opacity: 1, transform: "translateY(0) scale(1)" },
              { opacity: 0, transform: "translateY(10px) scale(0.985)" },
            ],
            {
              duration: 180,
              easing: "cubic-bezier(0.25, 1, 0.5, 1)",
              fill: "forwards",
            },
          ));
        }

        if (!prefersReducedMotion && typeof shell.animate === "function") {
          animations.push(shell.animate(
            [
              { opacity: 1 },
              { opacity: 0 },
            ],
            {
              duration: 180,
              easing: "cubic-bezier(0.25, 1, 0.5, 1)",
              fill: "forwards",
            },
          ));
        }

        if (animations.length > 0) {
          await Promise.allSettled(
            animations.map(function(animation) {
              return animation.finished;
            }),
          );
        }

        if (shell.open) shell.close();
        shell.remove();
      }

      function onKeydown(event) {
        if (event.key === "Escape") closeLightbox();
      }

      function onCancel(event) {
        event.preventDefault();
        closeLightbox();
      }

      function onDialogClick(event) {
        if (event.target === shell) closeLightbox();
      }

      function onPointerDown(event) {
        if (event.button !== 0) return;
        isDragging = true;
        dragStartX = event.clientX;
        dragStartY = event.clientY;
        dragScrollLeft = viewport.scrollLeft;
        dragScrollTop = viewport.scrollTop;
        shell.classList.add("is-dragging");
        viewport.setPointerCapture(event.pointerId);
      }

      function onPointerMove(event) {
        if (!isDragging) return;
        viewport.scrollLeft = dragScrollLeft - (event.clientX - dragStartX);
        viewport.scrollTop = dragScrollTop - (event.clientY - dragStartY);
      }

      function onPointerUp(event) {
        if (!isDragging) return;
        isDragging = false;
        shell.classList.remove("is-dragging");
        if (viewport.hasPointerCapture(event.pointerId)) {
          viewport.releasePointerCapture(event.pointerId);
        }
      }

      zoomOut.addEventListener("click", function() {
        applyZoom(zoom - 0.25, true);
      });
      zoomIn.addEventListener("click", function() {
        applyZoom(zoom + 0.25, true);
      });
      close.addEventListener("click", closeLightbox);
      viewport.addEventListener("scroll", updateButtons, { passive: true });
      viewport.addEventListener("pointerdown", onPointerDown);
      viewport.addEventListener("pointermove", onPointerMove);
      viewport.addEventListener("pointerup", onPointerUp);
      viewport.addEventListener("pointercancel", onPointerUp);
      window.addEventListener("resize", function() {
        applyZoom(zoom, false);
      }, { once: true });
      document.addEventListener("keydown", onKeydown);
      shell.addEventListener("cancel", onCancel);
      shell.addEventListener("click", onDialogClick);

      shell.showModal();
      requestAnimationFrame(function() {
        shell.classList.add("is-open");
      });
      applyZoom(minZoom, false);
      shell.focus();
    }
  })();
</script>


<style is:global>
  .blog-sheet {
    border-radius: var(--panel-radius);
    background: rgba(255, 255, 255, 0.8);
    box-shadow: 0 18px 45px rgba(47, 42, 68, 0.1);
    margin: 0 auto;
    overflow: hidden;
    position: relative;
  }

  .blog-hero {
    margin-bottom: clamp(-80px, -6vw, -48px);
    pointer-events: none;
  }

  .blog-hero img {
    display: block;
    width: 100%;
    height: clamp(280px, 42vw, 520px);
    object-fit: cover;
    -webkit-mask-image: linear-gradient(to bottom, black 78%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 78%, transparent 100%);
  }

  .blog-top,
  .blog-article {
    padding: 0 clamp(18px, 4vw, 36px);
  }

  .blog-top {
    padding-top: clamp(18px, 4vw, 36px);
    margin-bottom: 12px;
  }

  .blog-article {
    padding-bottom: clamp(18px, 4vw, 36px);
  }

  .blog-sheet.has-hero .blog-top {
    position: absolute;
    top: clamp(14px, 3vw, 24px);
    left: clamp(14px, 3vw, 24px);
    padding: 0;
    margin: 0;
    z-index: 2;
  }

  .blog-sheet.has-hero .blog-article {
    padding-top: clamp(22px, 4vw, 36px);
  }

  .blog-back {
    font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 14px;
    color: var(--muted);
    text-decoration: none;
  }

  .blog-sheet.has-hero .blog-back {
    display: inline-flex;
    align-items: center;
    padding: 7px 14px;
    border-radius: 999px;
    background: rgba(255, 252, 248, 0.82);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: var(--ink);
    border: 1px solid rgba(47, 42, 68, 0.1);
    box-shadow: 0 2px 8px rgba(47, 42, 68, 0.12);
  }

  .blog-back:hover {
    color: var(--accent);
  }

  .blog-sheet.has-hero .blog-back:hover {
    background: rgba(255, 252, 248, 0.95);
  }

  .blog-back:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .blog-header {
    margin-bottom: 24px;
  }

  .blog-header h1 {
    margin-top: 0;
  }

  .blog-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
    font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 14px;
    color: var(--muted);
  }

  .blog-meta-sep {
    opacity: 0.5;
  }

  .blog-author {
    color: var(--muted);
    text-decoration: none;
  }

  .blog-author:hover {
    color: var(--accent);
  }

  .blog-author:focus-visible,
  .blog-article.content a:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .blog-article.content {
    line-height: 1.55;
    font-size: clamp(16px, 1.5vw, 19px);
    color: var(--muted);
  }

  .blog-article.content img {
    max-width: 100%;
    height: auto;
  }

  .blog-article.content h1,
  .blog-article.content h2,
  .blog-article.content h3,
  .blog-article.content h4 {
    font-family: var(--font-heading);
    color: var(--ink);
    margin-top: 28px;
    margin-bottom: 12px;
    line-height: 1.2;
  }

  .blog-article.content h1 {
    font-size: clamp(28px, 4.2vw, 36px);
  }

  .blog-article.content h2 {
    font-size: clamp(24px, 3.6vw, 30px);
  }

  .blog-article.content h3 {
    font-size: clamp(20px, 3vw, 24px);
  }

  .blog-article.content p,
  .blog-article.content ul,
  .blog-article.content ol,
  .blog-article.content blockquote,
  .blog-article.content pre {
    margin: 14px 0;
  }

  .blog-article.content ul,
  .blog-article.content ol {
    padding-left: 24px;
  }

  .blog-article.content li {
    margin: 7px 0;
  }

  .blog-article.content a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 2px solid transparent;
  }

  .blog-article.content a:hover {
    border-bottom-color: var(--accent);
  }

  .blog-article.content code {
    font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.85em;
    padding: 2px 6px;
    border-radius: 8px;
    background: rgba(232, 135, 131, 0.12);
    color: var(--ink);
  }

  .blog-article.content pre {
    padding: 18px 20px;
    border: 2px solid var(--line);
    border-radius: 16px;
    background: var(--paper);
    overflow-x: auto;
    font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink);
  }

  .blog-article.content pre code {
    padding: 0;
    background: none;
  }

  .blog-article.content blockquote {
    background: var(--mint-soft);
    border-radius: 14px;
    padding: 14px 18px;
    color: var(--ink);
  }

  .blog-article.content strong {
    color: var(--ink);
  }

  .blog-article.content .table-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 18px 0;
  }

  .blog-article.content .diagram-shell {
    margin: 18px 0;
    position: relative;
  }

  .diagram-lightbox-toolbar .diagram-button {
    appearance: none;
    -webkit-appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    border: 1px solid rgba(47, 42, 68, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(6px);
    color: var(--ink);
    width: 44px;
    height: 44px;
    padding: 0;
    font: inherit;
    font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 13px;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(47, 42, 68, 0.07);
  }

  .diagram-lightbox-toolbar .diagram-button svg {
    display: block;
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    pointer-events: none;
  }

  .blog-article.content .diagram-viewport {
    overflow: hidden;
    padding: 0;
    max-height: none;
  }

  .blog-article.content .diagram-canvas {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .blog-article.content .diagram-image {
    display: block;
    max-width: 100%;
    height: auto;
    cursor: zoom-in !important;
  }

  .diagram-lightbox-toolbar .diagram-button:hover:not(:disabled) {
    background: rgba(232, 135, 131, 0.14);
  }

  .diagram-lightbox-toolbar .diagram-button:disabled {
    opacity: 0.45;
    cursor: default;
  }

  .diagram-lightbox-toolbar .diagram-button:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .diagram-lightbox {
    border: 0;
    padding: 0;
    max-width: none;
    max-height: none;
    width: 100vw;
    height: 100vh;
    z-index: 300;
    background: transparent;
    opacity: 0;
    transition: opacity 180ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  .diagram-lightbox::backdrop {
    background: rgba(24, 21, 39, 0.56);
    opacity: 0;
    transition: opacity 180ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  .diagram-lightbox.is-open {
    opacity: 1;
  }

  .diagram-lightbox.is-open::backdrop {
    opacity: 1;
  }

  .diagram-lightbox-panel {
    position: fixed;
    inset: 24px;
    border-radius: 24px;
    background: rgba(255, 252, 248, 0.96);
    box-shadow: 0 30px 80px rgba(24, 21, 39, 0.28);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(12px) scale(0.985);
    transition:
      opacity 180ms cubic-bezier(0.25, 1, 0.5, 1),
      transform 180ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  .diagram-lightbox.is-open .diagram-lightbox-panel {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .diagram-lightbox.is-closing {
    opacity: 0;
  }

  .diagram-lightbox.is-closing .diagram-lightbox-panel {
    opacity: 0;
    transform: translateY(8px) scale(0.99);
  }

  .diagram-lightbox-toolbar {
    display: flex;
    justify-content: flex-end;
    gap: 4px;
    padding: 8px 8px 0;
    flex-wrap: wrap;
  }

  .diagram-lightbox-close {
    width: 44px;
  }

  .diagram-lightbox-viewport {
    flex: 1;
    overflow: auto;
    -webkit-overflow-scrolling: touch;
    padding: 12px;
    cursor: grab;
    touch-action: none;
  }

  .diagram-lightbox-canvas {
    min-width: fit-content;
    min-height: 100%;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .diagram-lightbox-image {
    display: block;
    max-width: none;
    height: auto;
    user-select: none;
    cursor: grab !important;
  }

  .diagram-lightbox.is-dragging .diagram-lightbox-viewport,
  .diagram-lightbox.is-dragging .diagram-lightbox-image {
    cursor: grabbing !important;
  }

  .blog-article.content table {
    width: 100%;
    border-collapse: collapse;
    font-size: 15px;
    border: 2px solid var(--line);
  }

  .blog-article.content th,
  .blog-article.content td {
    border: 1px solid var(--line);
    padding: 8px 10px;
  }

  .blog-article.content th {
    font-family: "Nunito", sans-serif;
    color: var(--ink);
    background: rgba(155, 196, 182, 0.18);
  }

