---
import PostHog from "../components/posthog.astro";
import BaseScripts from "../components/layout/BaseScripts.astro";
import BaseStyles from "../components/layout/BaseStyles.astro";
import GoogleAnalytics from "../components/GoogleAnalytics.astro";
import SiteFooter from "../components/layout/SiteFooter.astro";
import SiteHeader from "../components/layout/SiteHeader.astro";
import { createCanonicalUrl } from "../utils/canonical";
import { getPageOgImageForPath } from "../data/page-og";

const DEFAULT_OG_IMAGE = "https://tako.sh/assets/og.png?v=20260613";

export interface Props {
	title?: string;
	description?: string;
	image?: string;
	imageAlt?: string;
	type?: string;
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
	noCanonical?: boolean;
}

const {
	title = "Tako - Ship it like FTP",
	description = "Everything you need to run apps on your own hardware. Routes, logs, secrets, rolling deploys, local dev — one tool.",
	image: imageOverride,
	imageAlt,
	type = "website",
	structuredData,
	noCanonical = false,
} = Astro.props;

const canonicalURL = createCanonicalUrl(Astro.url.pathname, Astro.site);
const image =
	imageOverride ??
	getPageOgImageForPath(Astro.url.pathname, Astro.site) ??
	DEFAULT_OG_IMAGE;
const organizationSchema = {
	"@context": "https://schema.org",
	"@type": "Organization",
	name: "Tako",
	url: "https://tako.sh",
	logo: "https://tako.sh/assets/og.png",
	sameAs: [
		"https://github.com/tako-sh/tako",
		"https://x.com/lilienblum",
		"https://discord.gg/2bvHr6gdbB",
	],
};
const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: "Tako",
	url: "https://tako.sh",
	description,
	publisher: {
		"@type": "Organization",
		name: "Tako",
		url: "https://tako.sh",
	},
	inLanguage: "en",
};
const baseStructuredData = JSON.stringify([organizationSchema, websiteSchema]);
const pageStructuredData = structuredData
	? JSON.stringify(
			Array.isArray(structuredData) ? structuredData : [structuredData],
		)
	: null;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		{!noCanonical && <link rel="canonical" href={canonicalURL} />}
		<meta property="og:type" content={type} />
		<meta property="og:site_name" content="Tako" />
		{!noCanonical && <meta property="og:url" content={canonicalURL} />}
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:image:secure_url" content={image} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={imageAlt ?? title} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@lilienblum" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />
		<meta name="twitter:image:alt" content={imageAlt ?? title} />
		<meta
			name="go-import"
			content="tako.sh git https://github.com/tako-sh/tako"
		/>
		<meta
			name="go-source"
			content="tako.sh https://github.com/tako-sh/tako https://github.com/tako-sh/tako/tree/master{/dir} https://github.com/tako-sh/tako/blob/master{/dir}/{file}#L{line}"
		/>
		<meta name="theme-color" content="#E88783" />
		<link rel="icon" type="image/svg+xml" href="/assets/logo.svg" />
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/assets/apple-touch-icon.png"
		/>
		<link
			rel="alternate"
			type="application/rss+xml"
			title="Tako Blog"
			href="/rss.xml"
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Caveat:wght@500&family=IBM+Plex+Mono:wght@400;700&family=Nunito:wght@400;600;700&family=Poppins:wght@600;700&display=swap"
			rel="stylesheet"
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=Caveat:wght@500&family=IBM+Plex+Mono:wght@400;700&family=Nunito:wght@400;600;700&family=Poppins:wght@600;700&display=swap"
				rel="stylesheet"
			/>
		</noscript>
		<script
			is:inline
			type="application/ld+json"
			set:html={baseStructuredData}
		/>
		{
			pageStructuredData && (
				<script
					is:inline
					type="application/ld+json"
					set:html={pageStructuredData}
				/>
			)
		}
		<BaseStyles />
		<slot name="head" />
		<GoogleAnalytics />
		<PostHog />
	</head>
	<body>
		<div class="site">
			<div class="header-sentinel" aria-hidden="true"></div>
			<SiteHeader />

			<div class="content-stack">
				<main class="container"><slot /></main>

				<SiteFooter />
			</div>
		</div>
		<BaseScripts />
	</body>
</html>
