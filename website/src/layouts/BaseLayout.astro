---
import { Image } from "astro:assets";
import NavLinks from "../components/NavLinks.astro";
import StarIcon from "lucide-astro/Star";
import ExternalLinkIcon from "lucide-astro/ExternalLink";
import PostHog from "../components/posthog.astro";
import { createCanonicalUrl } from "../utils/canonical";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  noCanonical?: boolean;
}

const {
  title = "Tako - Ship it like FTP",
  description = "Everything you need to run apps on your own hardware. Routes, logs, secrets, rolling deploys, local dev — one tool.",
  image = "https://tako.sh/assets/og.png",
  type = "website",
  structuredData,
  noCanonical = false,
} = Astro.props;

const canonicalURL = createCanonicalUrl(Astro.url.pathname, Astro.site);
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Tako",
  url: "https://tako.sh",
  logo: "https://tako.sh/assets/og.png",
  sameAs: [
    "https://github.com/lilienblum/tako",
    "https://x.com/lilienblum",
    "https://t.me/tako_sh",
  ],
};
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Tako",
  url: "https://tako.sh",
  description,
  publisher: {
    "@type": "Organization",
    name: "Tako",
    url: "https://tako.sh",
  },
  inLanguage: "en",
};
const baseStructuredData = JSON.stringify([organizationSchema, websiteSchema]);
const pageStructuredData = structuredData
  ? JSON.stringify(Array.isArray(structuredData) ? structuredData : [structuredData])
  : null;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {!noCanonical && <link rel="canonical" href={canonicalURL} />}
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Tako" />
    {!noCanonical && <meta property="og:url" content={canonicalURL} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@lilienblum" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="go-import" content="tako.sh git https://github.com/lilienblum/tako" />
    <meta name="go-source" content="tako.sh https://github.com/lilienblum/tako https://github.com/lilienblum/tako/tree/master{/dir} https://github.com/lilienblum/tako/blob/master{/dir}/{file}#L{line}" />
    <meta name="theme-color" content="#E88783" />
    <link rel="icon" type="image/svg+xml" href="/assets/logo.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title="Tako Blog" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@500&family=IBM+Plex+Mono:wght@400;700&family=Nunito:wght@400;600;700&family=Poppins:wght@600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Caveat:wght@500&family=IBM+Plex+Mono:wght@400;700&family=Nunito:wght@400;600;700&family=Poppins:wght@600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <script is:inline type="application/ld+json" set:html={baseStructuredData}></script>
    {pageStructuredData && <script is:inline type="application/ld+json" set:html={pageStructuredData}></script>}
    <style is:inline>
      html {
        scroll-behavior: smooth;
      }
      :root {
        --bg: oklch(94.2% 0.018 72);
        --paper: oklch(96.4% 0.014 72);
        --panel: color-mix(in oklch, var(--paper) 78%, var(--bg));
        --panel-strong: color-mix(in oklch, var(--paper) 90%, var(--bg));
        --panel-glass: color-mix(in srgb, var(--paper) 78%, transparent);
        --ink: #2f2a44;
        --primary: #E88783;
        --primary-text: #c4605c;
        --secondary: #9BC4B6;
        --gold: #D6A63E;
        --line: rgba(47, 42, 68, 0.16);
        --muted: rgba(47, 42, 68, 0.74);
        --accent: var(--primary-text);
        --accent-soft: rgba(232, 135, 131, 0.2);
        --primary-soft: rgba(232, 135, 131, 0.2);
        --primary-soft-border: rgba(232, 135, 131, 0.4);
        --primary-soft-hover: rgba(232, 135, 131, 0.32);
        --primary-soft-hover-border: rgba(232, 135, 131, 0.55);
        --primary-shadow: rgba(196, 96, 92, 0.22);
        --primary-shadow-lg: rgba(196, 96, 92, 0.28);
        --mint-soft: rgba(155, 196, 182, 0.3);
        --site-width: min(1080px, 92vw);
        --panel-radius: 30px;
        --font-sans: "Nunito", "Segoe UI", sans-serif;
        --font-heading: "Poppins", "Nunito", sans-serif;
      }

      @media (prefers-reduced-motion: no-preference) {
        @view-transition {
          navigation: auto;
        }
      }

      ::selection {
        background: rgba(232, 135, 131, 0.3);
        color: var(--ink);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html,
      body {
        min-height: 100%;
      }

      html {
        font-family: var(--font-sans);
      }

      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        font-family: var(--font-heading);
      }

      body {
        color: var(--ink);
        background: var(--bg);
        overflow-x: hidden;
      }

      .site {
        position: relative;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      .content-stack {
        display: flex;
        flex-direction: column;
        gap: 24px;
        margin: 10px 0 30px;
        flex: 1;
      }

      .container {
        width: var(--site-width);
        margin: 0 auto;
      }

      .header {
        position: sticky;
        top: 0;
        z-index: 100;
        padding: 14px 0;
      }

      .header > .container {
        position: relative;
      }

      .header-inner {
        padding: 11px 14px;
        border: 2px solid transparent;
        border-radius: var(--panel-radius);
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        transition:
          background 180ms ease,
          border-color 180ms ease,
          backdrop-filter 180ms ease;
      }

      .header.is-scrolled .header-inner {
        background: var(--panel-glass);
        border-color: var(--line);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
      }

      .header-sentinel {
        position: absolute;
        top: 0;
        left: 0;
        width: 1px;
        height: 1px;
        pointer-events: none;
      }

      .logo {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--ink);
        text-decoration: none;
        font-family: "Nunito", sans-serif;
        font-size: 22px;
        font-weight: 600;
        line-height: 1;
      }

      #logo-text {
        display: inline-block;
        width: 52px;
        font-size: 19px;
      }

      .logo img {
        width: 30px;
        height: 30px;
      }

      .nav-links {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .nav-links a {
        text-decoration: none;
        color: var(--ink);
        padding: 7px 8px;
        font-family: "Nunito", sans-serif;
        font-size: 16px;
        font-weight: 600;
        line-height: 1;
        transition: color 0.15s;
      }

      .nav-links a:hover {
        color: var(--accent);
      }

      .nav-links a:not(.github-star) {
        text-decoration: underline;
        text-decoration-color: transparent;
        transition: color 0.15s, text-decoration-color 180ms ease;
      }

      .nav-links a:not(.github-star):hover {
        text-decoration-color: currentColor;
      }

      .header.is-scrolled .nav-links a:not(.github-star):hover {
        text-decoration-color: transparent;
      }

      .nav-links a:focus-visible,
      .mobile-menu a:focus-visible,
      .hamburger:focus-visible {
        outline: 2px solid var(--primary);
        outline-offset: 2px;
      }

      .x-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 10px;
      }

      .telegram-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 9px 8px;
      }

      .telegram-link svg {
        width: 18px;
        height: 18px;
      }


      .github-star {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 7px 14px;
        border: 1px solid rgba(214, 166, 62, 0.88);
        border-radius: 999px;
        background: rgba(255, 224, 149, 0.24);
        color: #6f4d16;
        box-shadow: inset 0 0 0 1px rgba(255, 245, 210, 0.45);
      }

      .github-star .star-icon {
        width: 0.9em;
        height: 0.9em;
      }

      .github-star .star-icon path {
        fill: rgba(255, 214, 120, 0.22);
        stroke: currentColor;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .nav-links a.github-star:hover {
        transform: translateY(-1px);
        border-color: rgba(214, 166, 62, 1);
        background: rgba(255, 214, 120, 0.36);
        color: #5d3f0c;
        box-shadow: 0 2px 12px rgba(232, 185, 74, 0.34);
      }

      .nav-links a.github-star:hover .star-icon path {
        fill: rgba(255, 214, 120, 0.48);
      }

      .cloud-link {
        display: inline-flex;
        align-items: center;
        gap: 5px;
      }

      .cloud-link .cloud-icon {
        width: 0.9em;
        height: 0.9em;
      }

      .demo-link {
        display: inline-flex;
        align-items: center;
        gap: 4px;
      }

      .demo-link .demo-icon {
        width: 0.82em;
        height: 0.82em;
        stroke-width: 2.4;
      }

      .mobile-menu-icon {
        width: 16px;
        height: 16px;
        vertical-align: -2px;
        margin-right: 6px;
      }

      main {
        margin: 0 auto;
      }

      .site-footer {
        margin-top: auto;
        padding-top: 32px;
      }

      .footer-columns {
        display: grid;
        grid-template-columns: repeat(4, auto);
        justify-content: space-between;
        gap: 28px 24px;
        padding: 28px 14px 20px;
      }

      .footer-col {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .footer-col-title {
        font-family: "Nunito", sans-serif;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--ink);
        opacity: 0.7;
        margin-bottom: 6px;
      }

      .footer-col a {
        text-decoration: underline;
        text-decoration-color: transparent;
        color: var(--muted);
        font-family: "Nunito", sans-serif;
        font-size: 14px;
        font-weight: 500;
        transition: color 0.15s, text-decoration-color 180ms ease;
      }

      .footer-col a:hover {
        color: var(--ink);
        text-decoration-color: currentColor;
      }

      .footer-col a:focus-visible {
        outline: 2px solid var(--primary);
        outline-offset: 2px;
      }

      .footer-note {
        text-align: center;
        font-family: "Nunito", sans-serif;
        font-size: 13px;
        color: var(--muted);
        padding: 8px 14px 20px;
        border-top: 1px solid var(--line);
        margin: 0 14px;
      }

      @media (max-width: 720px) {
        .footer-columns {
          grid-template-columns: repeat(2, auto);
          gap: 24px 16px;
        }
      }

      .mobile-nav-controls {
        display: none;
        align-items: center;
        gap: 8px;
      }

      .hamburger {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 4px;
        width: 44px;
        height: 44px;
        padding: 8px;
        border: 1px solid transparent;
        border-radius: 999px;
        background: transparent;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
        transition: background 180ms ease, border-color 180ms ease;
      }

      .header.is-scrolled .hamburger {
        background: var(--panel-glass);
        border-color: var(--line);
      }

      .header.is-scrolled .hamburger:hover {
        background: rgba(232, 135, 131, 0.18);
      }

      .hamburger-line {
        display: block;
        width: 16px;
        height: 2px;
        background: var(--ink);
        border-radius: 1px;
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s ease;
        transform-origin: center;
      }

      .hamburger.is-open .hamburger-line:nth-child(1) {
        transform: translateY(6px) rotate(135deg);
      }

      .hamburger.is-open .hamburger-line:nth-child(2) {
        transform: scaleX(0);
        opacity: 0;
      }

      .hamburger.is-open .hamburger-line:nth-child(3) {
        transform: translateY(-6px) rotate(-135deg);
      }

      .mobile-menu {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 0 8px;
        margin-top: 0;
        border: 2px solid transparent;
        border-radius: 20px;
        background: color-mix(in srgb, var(--panel-strong) 94%, transparent);
        backdrop-filter: blur(8px);
        overflow: hidden;
        max-height: 0;
        opacity: 0;
        pointer-events: none;
        transition: max-height 0.25s ease, opacity 0.2s ease, padding 0.25s ease, margin-top 0.25s ease, border-color 0.2s ease;
      }

      .mobile-menu.is-open {
        max-height: 200px;
        opacity: 1;
        padding: 8px;
        margin-top: 8px;
        border-color: var(--line);
        pointer-events: auto;
      }

      .mobile-menu a {
        text-decoration: none;
        color: var(--ink);
        font-family: "Nunito", sans-serif;
        font-size: 16px;
        font-weight: 600;
        padding: 10px 14px;
        border-radius: 14px;
      }

      .mobile-menu a:hover,
      .mobile-menu a:active {
        background: rgba(232, 135, 131, 0.12);
      }




      @media (max-width: 640px) {
        .header-inner {
          padding: 10px;
        }

        .desktop-nav {
          display: none;
        }

        .mobile-nav-controls {
          display: flex;
        }
      }
    </style>
    <slot name="head" />
    <PostHog />
  </head>
  <body>
    <div class="site">
      <div class="header-sentinel" aria-hidden="true"></div>
      <header class="header">
        <div class="container">
          <div class="header-inner">
            <a href="/" class="logo" aria-label="Tako home">
              <Image src="/assets/logo.svg" alt="" width={30} height={30} loading="eager" aria-hidden="true" />
              <span id="logo-text"></span>
            </a>
            <nav class="nav nav-links desktop-nav">
              <NavLinks />
            </nav>
            <div class="mobile-nav-controls nav-links">
              <a href="/docs">docs</a>
              <a href="https://github.com/lilienblum/tako" target="_blank" rel="noopener noreferrer" class="github-star">
                <StarIcon class="star-icon" aria-hidden="true" focusable="false" />
                <span>github</span>
              </a>
              <button class="hamburger" aria-label="Toggle menu" aria-expanded="false">
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
              </button>
            </div>
          </div>
          <nav class="mobile-menu" id="mobile-menu" inert>
            <a href="https://demo.tako.sh" target="_blank" rel="noopener noreferrer"><ExternalLinkIcon class="mobile-menu-icon" aria-hidden="true" focusable="false" />demo</a>
            <a href="/blog"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" style="vertical-align: -2px; margin-right: 6px;"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>blog</a>
            <a href="https://twitter.com/intent/follow?screen_name=lilienblum" target="_blank" rel="noopener noreferrer"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false" style="vertical-align: -2px; margin-right: 6px;"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>follow progress</a>
            <a href="https://t.me/tako_sh" target="_blank" rel="noopener noreferrer"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 1000 1000" aria-hidden="true" focusable="false" style="vertical-align: -2px; margin-right: 6px;"><circle cx="500" cy="500" r="500" fill="currentColor"/><path d="M226.328419,494.722069 C372.088573,431.216685 469.284839,389.350049 517.917216,369.122161 C656.772535,311.36743 685.625481,301.334815 704.431427,301.003532 C708.567621,300.93067 717.815839,301.955743 723.806446,306.816707 C728.864797,310.92121 730.256552,316.46581 730.922551,320.357329 C731.588551,324.248848 732.417879,333.113828 731.758626,340.040666 C724.234007,419.102486 691.675104,610.964674 675.110982,699.515267 C668.10208,736.984342 654.301336,749.547532 640.940618,750.777006 C611.904684,753.448938 589.856115,731.588035 561.733393,713.153237 C517.726886,684.306416 492.866009,666.349181 450.150074,638.200013 C400.78442,605.66878 432.786119,587.789048 460.919462,558.568563 C468.282091,550.921423 596.21508,434.556479 598.691227,424.000355 C599.00091,422.680135 599.288312,417.758981 596.36474,415.160431 C593.441168,412.561881 589.126229,413.450484 586.012448,414.157198 C581.598758,415.158943 511.297793,461.625274 375.109553,553.556189 C355.154858,567.258623 337.080515,573.934908 320.886524,573.585046 C303.033948,573.199351 268.692754,563.490928 243.163606,555.192408 C211.851067,545.013936 186.964484,539.632504 189.131547,522.346309 C190.260287,513.342589 202.659244,504.134509 226.328419,494.722069 Z" fill="#FFFFFF"/></svg>telegram</a>
          </nav>
        </div>
      </header>

      <div class="content-stack">
        <main class="container"><slot /></main>

        <footer class="site-footer">
          <div class="container">
            <div class="footer-columns">
              <div class="footer-col">
                <h3 class="footer-col-title">Docs</h3>
                <a href="/docs/quickstart">Quickstart</a>
                <a href="/docs/how-tako-works">How Tako works</a>
                <a href="/docs/cli">CLI reference</a>
                <a href="/docs/tako-toml">tako.toml</a>
                <a href="/docs/troubleshooting">Troubleshooting</a>
              </div>
              <div class="footer-col">
                <h3 class="footer-col-title">Guides</h3>
                <a href="/docs/deployment">Deployment</a>
                <a href="/docs/development">Development</a>
                <a href="/docs/presets">Presets</a>
                <a href="/docs/framework-guides">Framework guides</a>
              </div>
              <div class="footer-col">
                <h3 class="footer-col-title">Project</h3>
                <a href="/blog">Blog</a>
                <a href="https://github.com/lilienblum/tako" target="_blank" rel="noopener noreferrer">GitHub</a>
                <a href="https://t.me/tako_sh" target="_blank" rel="noopener noreferrer">Telegram</a>
                <a href="https://twitter.com/intent/follow?screen_name=lilienblum" target="_blank" rel="noopener noreferrer">X</a>
              </div>
              <div class="footer-col">
                <h3 class="footer-col-title">Feeds</h3>
                <a href="/rss.xml">RSS feed</a>
                <a href="/llms.txt">LLMs.txt</a>
              </div>
            </div>
            <p class="footer-note">open source will win &middot; made in Japan</p>
          </div>
        </footer>

      </div>

    </div>
    <script is:inline>
      (function() {
        var hamburger = document.querySelector('.hamburger');
        var mobileMenu = document.getElementById('mobile-menu');
        if (!hamburger || !mobileMenu) return;
        hamburger.addEventListener('click', function(e) {
          e.stopPropagation();
          var isOpen = mobileMenu.classList.toggle('is-open');
          hamburger.classList.toggle('is-open');
          hamburger.setAttribute('aria-expanded', String(isOpen));
          if (isOpen) {
            mobileMenu.removeAttribute('inert');
          } else {
            mobileMenu.setAttribute('inert', '');
          }
        });
        document.addEventListener('click', function(e) {
          if (!mobileMenu.contains(e.target) && !hamburger.contains(e.target)) {
            mobileMenu.classList.remove('is-open');
            hamburger.classList.remove('is-open');
            hamburger.setAttribute('aria-expanded', 'false');
            mobileMenu.setAttribute('inert', '');
          }
        });
      })();
    </script>
    <script is:inline>
      (function() {
        var sentinel = document.querySelector('.header-sentinel');
        var header = document.querySelector('.header');
        if (!sentinel || !header || typeof IntersectionObserver === 'undefined') return;
        var io = new IntersectionObserver(function(entries) {
          header.classList.toggle('is-scrolled', !entries[0].isIntersecting);
        });
        io.observe(sentinel);
      })();
    </script>
    <script is:inline>
      (function() {
        var el = document.getElementById('logo-text');
        if (!el) return;
        if (window.location.pathname !== '/') {
          el.textContent = 'tako';
          el.style.fontFamily = '"Nunito", sans-serif';
          return;
        }
        var mono = '"IBM Plex Mono", monospace';
        var sans = '"Nunito", sans-serif';
        function rbit() { return Math.random() > 0.5 ? '1' : '0'; }

        // Phase 1: show たこ for 700ms
        el.textContent = 'たこ';
        setTimeout(function() {
          // Phase 2: clean swap to binary
          el.style.fontFamily = mono;
          var b = '';
          for (var j = 0; j < 4; j++) b += rbit();
          el.textContent = b;
          // Brief scramble
          var s = 0;
          var scramble = setInterval(function() {
            var b = '';
            for (var j = 0; j < 4; j++) b += rbit();
            el.textContent = b;
            s++;
            if (s >= 6) {
              clearInterval(scramble);
              // Phase 3: binary → tako, letter by letter
              var cur = el.textContent;
              var k = 0;
              var toTako = setInterval(function() {
                cur = 'tako'.slice(0, k + 1) + cur.slice(k + 1);
                el.textContent = cur;
                if (k === 0) {
                  el.style.fontFamily = sans;
                }
                k++;
                if (k >= 4) {
                  clearInterval(toTako);
                }
              }, 150);
            }
          }, 70);
        }, 700);
      })();
    </script>
    <script is:inline>
      (function() {
        document.querySelectorAll('a[href*="github.com"]').forEach(function(link) {
          link.addEventListener('click', function() {
            window.posthog?.capture('github_clicked', {
              href: link.getAttribute('href'),
              location: link.closest('header') ? 'header' : 'footer',
            });
          });
        });
        document.querySelectorAll('a[href*="t.me/"]').forEach(function(link) {
          link.addEventListener('click', function() {
            window.posthog?.capture('telegram_clicked', {
              href: link.getAttribute('href'),
              location: link.closest('header') ? 'header' : 'footer',
            });
          });
        });
      })();
    </script>
    <script is:inline>
      (function() {
        if (!('navigator' in window) || !navigator.modelContext || typeof navigator.modelContext.provideContext !== 'function') return;
        var DOC_PAGES = [
          'quickstart', 'cli', 'deployment', 'development', 'troubleshooting',
          'how-tako-works', 'tako-toml', 'framework-guides', 'presets'
        ];
        var GETTING_STARTED =
          '1. Install the CLI:  curl -fsSL https://tako.sh/install.sh | sh\n' +
          '2. Scaffold a project:  tako init\n' +
          '3. Run the dev loop:  tako dev';
        var INSTALL = {
          cli: 'curl -fsSL https://tako.sh/install.sh | sh',
          server: 'curl -fsSL https://tako.sh/install-server.sh | sudo sh'
        };
        try {
          navigator.modelContext.provideContext({
            tools: [
              {
                name: 'navigateToDocs',
                description: 'Navigate the current tab to a tako.sh documentation page.',
                inputSchema: {
                  type: 'object',
                  properties: { page: { type: 'string', enum: DOC_PAGES, description: 'Doc slug under /docs/.' } },
                  required: ['page']
                },
                execute: function(input) {
                  window.location.assign('/docs/' + input.page);
                  return 'Navigating to /docs/' + input.page;
                }
              },
              {
                name: 'searchDocs',
                description: 'Search the tako.sh docs. Opens /docs with the query in the URL.',
                inputSchema: {
                  type: 'object',
                  properties: { query: { type: 'string', minLength: 1, description: 'Free-text search query.' } },
                  required: ['query']
                },
                execute: function(input) {
                  var q = encodeURIComponent(String(input.query).slice(0, 256));
                  window.location.assign('/docs?q=' + q);
                  return 'Opened docs with query "' + input.query + '".';
                }
              },
              {
                name: 'getStartedCommand',
                description: 'Return the three-step tako.sh getting-started commands as plain text.',
                inputSchema: { type: 'object', properties: {} },
                execute: function() { return GETTING_STARTED; }
              },
              {
                name: 'getInstallCommand',
                description: 'Return the one-line curl install command for the tako CLI or the tako server.',
                inputSchema: {
                  type: 'object',
                  properties: { kind: { type: 'string', enum: ['cli', 'server'] } },
                  required: ['kind']
                },
                execute: function(input) { return INSTALL[input.kind]; }
              }
            ]
          });
        } catch (_e) { /* ignore */ }
      })();
    </script>
  </body>
</html>
